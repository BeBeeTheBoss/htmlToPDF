    "html": "<!DOCTYPE html>\n<html lang=\"my\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <style>\n    @page { size: A4; margin: 8mm; }\n    * { box-sizing: border-box; font-family: 'Pyidaungsu', 'Segoe UI', Tahoma, sans-serif; margin: 0; padding: 0; }\n    body { background: #fff; color: #111; }\n\n    .sheet {\n      height: 281mm;\n      display: flex;\n      flex-direction: column;\n      gap: 4.5mm;\n      page-break-after: always;\n    }\n    .sheet:last-child { page-break-after: auto; }\n\n    .voucher-card {\n      width: 92%;\n      margin: 0 auto;\n      height: 90mm;\n      border: 2px solid #2076d2;\n      border-radius: 18px;\n      padding: 10px 12px;\n      display: flex;\n      flex-direction: column;\n      page-break-inside: avoid;\n    }\n\n    .header {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      height: 34px;\n      margin-bottom: 4px;\n    }\n\n    .logo-img { height: 28px; object-fit: contain; }\n\n    .header-text {\n      text-align: right;\n      color: #e52d27;\n      font-size: 14px;\n      font-weight: 700;\n      line-height: 1.35;\n    }\n\n    .main-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      grid-template-rows: 1fr 26px;\n      flex-grow: 1;\n      border-top: 2px solid #2076d2;\n      position: relative;\n    }\n\n    .main-grid::before {\n      content: \"\";\n      position: absolute;\n      top: 0;\n      bottom: 0;\n      left: 50%;\n      width: 2px;\n      background: #2076d2;\n    }\n\n    .content-box {\n      padding-top: 7px;\n      font-size: 14px;\n      line-height: 1.45;\n      color: #333;\n    }\n\n    .box-left { padding-right: 10px; }\n    .box-right { padding-left: 10px; }\n\n    .section-title {\n      font-size: 16px;\n      font-weight: 700;\n      color: #111;\n      margin-bottom: 2px;\n    }\n\n    .details {\n      --label-col: max-content;\n     